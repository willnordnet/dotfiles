      "Bash(npx create-vite@latest . --template react-ts)",
      "Bash(npm install)",
      "Bash(npx tsc:*)",
      "Bash(npm run build:*)",
      "Bash(npm test:*)",
      "Bash(npm run deploy:*)",
      "Bash(npx wrangler pages deploy:*)",
      "Bash(npx wrangler pages project create:*)",
      "WebSearch",
      "WebFetch(domain:pixabay.com)",
      "Bash(gh workflow:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(timeout 10 npm run dev:*)",
      "Bash(node -e:*)",
      "Bash(ls:*)"
